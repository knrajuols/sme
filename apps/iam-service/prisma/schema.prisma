generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// tenantId = 'platform' for PLATFORM_ADMIN users; UUID for school users.
// email uniqueness is scoped per tenant (RISK-01 fix).
model User {
  id                 String     @id @default(uuid())
  tenantId           String     @db.VarChar(50)
  email              String?    @db.VarChar(255)
  username           String?    @db.VarChar(100)
  displayName        String     @db.VarChar(200)
  // VarChar(255): bcrypt=60 chars, argon2id≤97 chars; 255 gives headroom for future algorithms.
  passwordHash       String     @db.VarChar(255)
  status             UserStatus @default(ACTIVE)
  failedLoginCount   Int        @default(0)
  lastFailedLoginAt  DateTime?
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  mustChangePassword Boolean    @default(false)
  softDelete         Boolean    @default(false)
  version            Int        @default(1)
  createdBy          String?    @db.VarChar(50)
  updatedBy          String?    @db.VarChar(50)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  userRoles      UserRole[]
  userAttributes UserAttribute[]
  refreshTokens  RefreshToken[]
  resetTokens    PasswordResetToken[]
  loginAudits    LoginAudit[]

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([email])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  PENDING_RESET
}

// ─── Role ─────────────────────────────────────────────────────────────────────
// tenantId = 'platform' for system roles; tenant UUID for custom school roles.
// code uniqueness is scoped per tenant (RISK-02 fix).
model Role {
  id          String   @id @default(uuid())
  tenantId    String   @db.VarChar(50)
  code        String   @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  isSystem    Boolean  @default(false)
  softDelete  Boolean  @default(false)
  version     Int      @default(1)
  createdBy   String?  @db.VarChar(50)
  updatedBy   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Permission ───────────────────────────────────────────────────────────────
// Platform-defined constants — seeded once; code is globally unique.
model Permission {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(200)
  moduleKey String   @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
}

// ─── RolePermission ───────────────────────────────────────────────────────────
// Ties a permission to a role. Scoped by tenantId (RISK-02 fix).
model RolePermission {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
}

// ─── UserRole ─────────────────────────────────────────────────────────────────
// User-to-role assignment, fully tenant-scoped (RISK-02 fix).
model UserRole {
  id        String   @id @default(uuid())
  tenantId  String   @db.VarChar(50)
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  createdBy String?  @db.VarChar(50)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@index([userId])
}

// ─── UserAttribute ────────────────────────────────────────────────────────────
// ABAC key-value attributes per user (e.g. campusId, departmentId). RISK-03 fix.
model UserAttribute {
  id        String   @id @default(uuid())
  tenantId  String   @db.VarChar(50)
  userId    String
  attrKey   String   @db.VarChar(100)
  attrValue String   @db.VarChar(500)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, attrKey])
  @@index([tenantId])
  @@index([userId])
}

// ─── RefreshToken ─────────────────────────────────────────────────────────────
// Only the SHA-256 hash of the raw token is stored — never the raw token.
// tokenHash is SHA-256 hex = exactly 64 chars; CHAR(64) is faster than VARCHAR
// for fixed-width equality checks and avoids per-row length-prefix overhead.
model RefreshToken {
  id            String    @id @default(uuid())
  tenantId      String    @db.VarChar(50)
  userId        String
  sessionId     String    @db.VarChar(50)
  tokenHash     String    @unique @db.Char(64)
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?   @db.VarChar(200)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([sessionId])
  @@index([expiresAt])
}

// ─── PasswordResetToken ───────────────────────────────────────────────────────
// One-time use password reset tokens — hash only.
// tokenHash: SHA-256 hex = CHAR(64) — fixed-width, no length prefix.
model PasswordResetToken {
  id        String    @id @default(uuid())
  tenantId  String    @db.VarChar(50)
  userId    String
  tokenHash String    @unique @db.Char(64)
  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

// ─── LoginAudit ───────────────────────────────────────────────────────────────
// Lightweight per-request login audit for lockout state and forensic analysis.
model LoginAudit {
  id              String   @id @default(uuid())
  tenantId        String   @db.VarChar(50)
  userId          String?
  loginIdentifier String   @db.VarChar(255)
  success         Boolean
  ipAddress       String?  @db.VarChar(45)
  userAgent       String?  @db.VarChar(500)
  failReason      String?  @db.VarChar(200)
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  // Hot-path for account lockout: WHERE loginIdentifier = ? AND tenantId = ?
  @@index([tenantId, loginIdentifier])
}

// ─── IdempotencyKey ───────────────────────────────────────────────────────────
// Prevents duplicate mutations on client retries (RISK-06 fix).
// Stored in IAM DB for auth mutations; gateway uses Redis for stateless check.
model IdempotencyKey {
  id             String   @id @default(uuid())
  tenantId       String   @db.VarChar(50)
  // SHA-256(method + path + body) → always 64 hex chars
  keyHash        String   @db.Char(64)
  requestPath    String   @db.VarChar(500)
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([tenantId, keyHash])
  @@index([tenantId])
  @@index([expiresAt])
}

// ─── ProcessedEvent ───────────────────────────────────────────────────────────
model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String   @db.VarChar(100)
  processedAt DateTime @default(now())

  @@index([processedAt])
}
