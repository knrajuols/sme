generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AuditEvent ───────────────────────────────────────────────────────────────
// IMMUTABLE — application code must never UPDATE or DELETE rows.
// tenantId is NON-NULLABLE (RISK-04 fix).
model AuditEvent {
  id             String         @id @default(uuid())
  tenantId       String         @db.VarChar(50)
  correlationId  String         @db.VarChar(50)
  actorType      AuditActorType
  actorId        String?        @db.VarChar(50)
  actorRole      String?        @db.VarChar(100)
  moduleKey      String         @db.VarChar(50)
  entityType     String         @db.VarChar(100)
  entityId       String         @db.VarChar(50)
  action         String         @db.VarChar(50)
  beforeSnapshot Json?
  afterSnapshot  Json?
  reason         String?        @db.VarChar(500)
  sourceService  String         @db.VarChar(100)
  ipAddress      String?        @db.VarChar(45)
  userAgent      String?        @db.VarChar(500)
  rowHash        String?        @db.VarChar(64)
  createdAt      DateTime       @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, moduleKey])
  @@index([tenantId, entityType, entityId])
  @@index([correlationId])
  // Compound index: forensic queries are always scoped by tenant first.
  @@index([tenantId, actorId])
}

enum AuditActorType {
  USER
  SYSTEM
  SCHEDULED_JOB
}

// ─── AuditRetentionPolicy ─────────────────────────────────────────────────────
model AuditRetentionPolicy {
  id            String   @id @default(uuid())
  tenantId      String   @unique @db.VarChar(50)
  retentionDays Int      @default(2555)
  isActive      Boolean  @default(true)
  createdBy     String?  @db.VarChar(50)
  updatedBy     String?  @db.VarChar(50)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AuditExportJob ───────────────────────────────────────────────────────────
model AuditExportJob {
  id          String          @id @default(uuid())
  tenantId    String          @db.VarChar(50)
  requestedBy String          @db.VarChar(50)
  status      ExportJobStatus @default(PENDING)
  filtersJson Json
  // VarChar(1024): accommodates S3/GCS/Azure Blob internal key paths; pre-signed URLs must NOT be stored here.
  fileUrl     String?         @db.VarChar(1024)
  format      String          @default("csv") @db.VarChar(10)
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  // VarChar(2000): fits exception class + message + first-line frame; full traces belong in log aggregator.
  errorMsg    String?         @db.VarChar(2000)

  @@index([tenantId])
  @@index([status])
  // "My export jobs" query: WHERE tenantId = ? AND requestedBy = ?
  @@index([tenantId, requestedBy])
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── ProcessedEvent ───────────────────────────────────────────────────────────
model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String   @db.VarChar(100)
  processedAt DateTime @default(now())

  @@index([processedAt])
}
