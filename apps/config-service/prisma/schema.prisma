generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ConfigMaster ─────────────────────────────────────────────────────────────
// Versioned per-tenant configuration. One row = one (type, key, version).
// Rollback = set old version isActive=true, new version isActive=false.
// tenantId is UUID (RISK-05 fix — replaced tenantCode FK).
model ConfigMaster {
  id         String   @id @default(uuid())
  tenantId   String   @db.VarChar(50)
  configType String   @db.VarChar(100)
  configKey  String   @db.VarChar(200)
  payload    Json
  version    Int      @default(1)
  isActive   Boolean  @default(true)
  softDelete Boolean  @default(false)
  createdBy  String?  @db.VarChar(50)
  updatedBy  String?  @db.VarChar(50)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, configType, configKey, version])
  @@index([tenantId])
  @@index([tenantId, configType])
  @@index([tenantId, isActive])
}

// ─── ModuleEntitlement ────────────────────────────────────────────────────────
// Module on/off switch per tenant — gateway reads this for route enforcement.
model ModuleEntitlement {
  id         String    @id @default(uuid())
  tenantId   String    @db.VarChar(50)
  moduleKey  String    @db.VarChar(50)
  enabled    Boolean   @default(false)
  enabledBy  String?   @db.VarChar(50)
  disabledBy String?   @db.VarChar(50)
  enabledAt  DateTime?
  disabledAt DateTime?
  softDelete Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// ─── FeatureFlag ──────────────────────────────────────────────────────────────
// Experimental feature flags — off by default.
model FeatureFlag {
  id          String   @id @default(uuid())
  tenantId    String   @db.VarChar(50)
  flagKey     String   @db.VarChar(100)
  enabled     Boolean  @default(false)
  description String?  @db.VarChar(500)
  createdBy   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, flagKey])
  @@index([tenantId])
}

// ─── ProcessedEvent ───────────────────────────────────────────────────────────
model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String   @db.VarChar(100)
  processedAt DateTime @default(now())

  @@index([processedAt])
}
