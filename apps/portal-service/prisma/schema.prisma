// =============================================================================
// WARNING: READ-ONLY SCHEMA.
// DO NOT RUN MIGRATE OR DB PUSH ON THIS FILE.
// SCHEMA IS MANAGED EXCLUSIVELY BY TENANT-SERVICE.
// This file defines a read-only CQRS projection client for the portal-service.
// Any schema changes must be made in apps/tenant-service/prisma/schema.prisma
// and deployed via that service's migration pipeline.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Portal Projections ───────────────────────────────────────────────────────
// These are READ-ONLY denormalized projections populated via events.
// Each model carries lastSyncedAt to surface data-freshness to consumers (RISK-10 fix).
// Portal service MUST NOT be treated as the canonical source of truth.

model Parent {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  userId       String   @db.VarChar(50)
  firstName    String   @db.VarChar(100)
  lastName     String   @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  email        String?  @db.VarChar(255)
  relation     String   @db.VarChar(50)
  createdBy    String?  @db.VarChar(50)
  updatedBy    String?  @db.VarChar(50)
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
}

model ParentStudentMapping {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  parentId     String
  studentId    String
  createdBy    String?  @db.VarChar(50)
  updatedBy    String?  @db.VarChar(50)
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, parentId, studentId])
  @@index([tenantId])
  @@index([parentId])
  @@index([studentId])
}

model Student {
  id              String   @id @default(uuid())
  tenantId        String   @db.VarChar(50)
  admissionNumber String   @db.VarChar(50)
  firstName       String   @db.VarChar(100)
  lastName        String   @db.VarChar(100)
  status          String   @db.VarChar(20)
  softDelete      Boolean  @default(false)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, admissionNumber])
  @@index([tenantId])
}

model AttendanceSession {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  date         DateTime @db.Date
  classId      String?  @db.VarChar(50)
  sectionId    String?  @db.VarChar(50)
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
}

model AttendanceRecord {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  sessionId    String
  studentId    String
  status       String   @db.VarChar(20)
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([sessionId])
  @@index([studentId])
}

model Exam {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  name         String   @db.VarChar(200)
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model StudentExamAggregate {
  id           String   @id @default(uuid())
  tenantId     String   @db.VarChar(50)
  examId       String
  studentId    String
  totalMarks   Float
  percentage   Float
  grade        String   @db.VarChar(10)
  classRank    Int?
  sectionRank  Int?
  gpa          Float?
  softDelete   Boolean  @default(false)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, examId, studentId])
  @@index([tenantId])
  @@index([examId])
  @@index([studentId])
}

// ─── ProcessedEvent ───────────────────────────────────────────────────────────
model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String   @db.VarChar(100)
  processedAt DateTime @default(now())

  @@index([processedAt])
}
