{
  "name": "sme",
  "version": "1.0.0",
  "private": true,
  "description": "SME - School Management Excellence monorepo",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:all": "concurrently --names iam,tenant,config,audit,portal,gateway --prefix-colors blue,magenta,cyan,yellow,white,green \"npm run start:dev -w @sme/iam-service\" \"npm run start:dev -w @sme/tenant-service\" \"npm run start:dev -w @sme/config-service\" \"npm run start:dev -w @sme/audit-service\" \"npm run start:dev -w @sme/portal-service\" \"npm run start:dev -w @sme/api-gateway\"",
    "verify:health": "node scripts/verify-health.js",
    "smoke:onboard": "node scripts/smoke-onboard.js",
    "academic:smoke": "node scripts/academic-smoke.js",
    "attendance:smoke": "node scripts/attendance-smoke.js",
    "exam:smoke": "node scripts/exam-smoke.js",
    "analytics:smoke": "node scripts/analytics-smoke.js",
    "portal:smoke": "node scripts/portal-smoke.js",
    "security:validate": "node scripts/security-validate.js",
    "start:dev:api-gateway": "npm run start:dev -w @sme/api-gateway",
    "start:dev:iam": "npm run start:dev -w @sme/iam-service",
    "start:dev:tenant": "npm run start:dev -w @sme/tenant-service",
    "start:dev:config": "npm run start:dev -w @sme/config-service",
    "start:dev:audit": "npm run start:dev -w @sme/audit-service",
    "start:dev:portal": "npm run start:dev -w @sme/portal-service",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,json,md}\"",
    "prisma:generate": "npm run prisma:generate --workspaces --if-present",
    "prisma:migrate:dev": "npm run prisma:migrate:dev --workspaces --if-present"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "4.16.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.4.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.2",
    "prisma": "4.16.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
